{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Light Again",
  "version": "1.0.0",
  "identifier": "com.paolocolombat.lightagain",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File build-dist.ps1",
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File build-dist.ps1"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Light Again",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
